#!/bin/sh

BACKEND="${BACKEND:-/usr/sbin/owrt-full-backup}"
KEY_FILE="${KEY_FILE:-/etc/owrt-full-backup/web.key}"
PARAMS_FILE="${TMPDIR:-/tmp}/owrt-full-backup-cgi.$$"
RESULT_FILE=""
RESULT_TITLE=""
RESULT_CODE=""
JOB_DIR="${JOB_DIR:-/tmp/owrt-full-backup-jobs}"
ACTIVE_JOB=""
PROJECT_URL="${PROJECT_URL:-https://github.com/kzolotarev95/luci-app-owrt-full-backup}"
RAW_URL="${RAW_URL:-https://raw.githubusercontent.com/kzolotarev95/luci-app-owrt-full-backup/main}"

cleanup() {
	rm -f "$PARAMS_FILE"
	if [ -n "$RESULT_FILE" ]; then
		rm -f "$RESULT_FILE"
	fi
}

trap cleanup EXIT INT TERM

html_escape() {
	sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g'
}

h() {
	printf '%s' "$1" | html_escape
}

url_decode() {
	local data
	data="$(printf '%s' "$1" | sed 's/+/ /g; s/%/\\x/g')"
	printf '%b' "$data"
}

parse_params() {
	local data old_ifs pair key value
	data="$1"
	old_ifs="$IFS"
	IFS='&'
	for pair in $data; do
		key="${pair%%=*}"
		value="${pair#*=}"
		[ "$pair" = "$key" ] && value=""
		key="$(url_decode "$key" | tr -d '\r\n\t')"
		value="$(url_decode "$value" | tr '\r\n\t' '   ')"
		[ -n "$key" ] && printf '%s\t%s\n' "$key" "$value" >>"$PARAMS_FILE"
	done
	IFS="$old_ifs"
}

param() {
	awk -F '	' -v k="$1" '$1 == k { print $2; exit }' "$PARAMS_FILE"
}

has_param() {
	awk -F '	' -v k="$1" '$1 == k { found = 1 } END { exit(found ? 0 : 1) }' "$PARAMS_FILE"
}

read_request() {
	local post_data
	: >"$PARAMS_FILE"
	parse_params "${QUERY_STRING:-}"
	case "${CONTENT_TYPE:-}" in
		multipart/form-data*) return ;;
	esac
	if [ "${REQUEST_METHOD:-GET}" = "POST" ] && [ -n "${CONTENT_LENGTH:-}" ]; then
		post_data="$(dd bs=1 count="$CONTENT_LENGTH" 2>/dev/null)"
		parse_params "$post_data"
	fi
}

config_get() {
	local key default value
	key="$1"
	default="$2"
	if command -v uci >/dev/null 2>&1; then
		value="$(uci -q get "fullbackup.main.$key" 2>/dev/null || true)"
		[ -n "$value" ] && {
			printf '%s' "$value"
			return
		}
	fi
	printf '%s' "$default"
}

web_key() {
	cat "$KEY_FILE" 2>/dev/null
}

self_url() {
	printf '%s' "${SCRIPT_NAME:-/cgi-bin/owrt-full-backup}"
}

authorized() {
	local expected supplied
	expected="$(web_key)"
	supplied="$(param key)"
	[ -n "$expected" ] && [ "$supplied" = "$expected" ]
}

http_html() {
	printf 'Content-Type: text/html; charset=utf-8\r\n'
	printf 'Cache-Control: no-store, no-cache, must-revalidate, max-age=0\r\n'
	printf 'Pragma: no-cache\r\n'
	printf 'Expires: 0\r\n\r\n'
}

http_unauthorized() {
	http_html
	cat <<'EOF'
<!doctype html><html><head><meta charset="utf-8"><title>OpenWrt Full Backup</title></head>
<body><h1>Доступ запрещен</h1><p>Открой панель по секретной ссылке, которую показал install.sh.</p></body></html>
EOF
}

valid_abs_path() {
	case "$1" in
		/*) ;;
		*) return 1 ;;
	esac
	printf '%s' "$1" | grep -Eq '^/[A-Za-z0-9._/-]+$'
}

valid_job_id() {
	case "$1" in
		''|*[!A-Za-z0-9._-]*) return 1 ;;
		*) return 0 ;;
	esac
}

shell_quote() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

job_file() {
	printf '%s/%s.%s' "$JOB_DIR" "$1" "$2"
}

format_seconds() {
	local seconds minutes rest
	seconds="$1"
	case "$seconds" in ''|*[!0-9]*) seconds=0 ;; esac
	minutes="$((seconds / 60))"
	rest="$((seconds % 60))"
	if [ "$minutes" -gt 0 ]; then
		printf '%s мин %s сек' "$minutes" "$rest"
	else
		printf '%s сек' "$rest"
	fi
}

localize_log() {
	sed \
		-e 's/^Старт: /Начало: /' \
		-e 's/^Код выхода: 0$/Готово./' \
		-e 's/Sun/Вс/g' -e 's/Mon/Пн/g' -e 's/Tue/Вт/g' -e 's/Wed/Ср/g' -e 's/Thu/Чт/g' -e 's/Fri/Пт/g' -e 's/Sat/Сб/g' \
		-e 's/Jan/Янв/g' -e 's/Feb/Фев/g' -e 's/Mar/Мар/g' -e 's/Apr/Апр/g' -e 's/May/Май/g' -e 's/Jun/Июн/g' \
		-e 's/Jul/Июл/g' -e 's/Aug/Авг/g' -e 's/Sep/Сен/g' -e 's/Oct/Окт/g' -e 's/Nov/Ноя/g' -e 's/Dec/Дек/g'
}

download_file() {
	local file base
	file="$(param file)"
	valid_abs_path "$file" || {
		http_html
		printf '<p>Неверный путь к файлу.</p>'
		exit 0
	}
	case "$file" in
		*.tar.gz|*.tar.gz.sha256) ;;
		*) http_html; printf '<p>Скачать можно только архивы бэкапа и checksum-файлы.</p>'; exit 0 ;;
	esac
	[ -f "$file" ] || {
		http_html
		printf '<p>Файл не найден.</p>'
		exit 0
	}
	base="$(basename "$file")"
	case "$file" in
		*.sha256) printf 'Content-Type: text/plain\r\n' ;;
		*) printf 'Content-Type: application/gzip\r\n' ;;
	esac
	printf 'Content-Disposition: attachment; filename="%s"\r\n\r\n' "$base"
	cat "$file"
	exit 0
}

handle_delete_backup() {
	local file confirm
	file="$(param file)"
	confirm="$(param confirm)"
	RESULT_TITLE="Удаление бэкапа"
	RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"

	if [ "$confirm" != "DELETE" ]; then
		RESULT_CODE=2
		printf 'Для удаления введи DELETE.\n' >"$RESULT_FILE"
		return
	fi

	valid_abs_path "$file" || {
		RESULT_CODE=2
		printf 'Неверный путь к файлу.\n' >"$RESULT_FILE"
		return
	}

	case "$file" in
		*.tar.gz|*.tar.gz.sha256) ;;
		*)
			RESULT_CODE=2
			printf 'Удалять можно только архивы бэкапа и checksum-файлы.\n' >"$RESULT_FILE"
			return
			;;
	esac

	if [ ! -f "$file" ]; then
		RESULT_TITLE="Бэкап уже удален"
		RESULT_CODE=0
		printf 'Архив уже удален или его нет в папке: %s\n' "$file" >"$RESULT_FILE"
		return
	fi

	if rm -f "$file" "$file.sha256" 2>"$RESULT_FILE"; then
		RESULT_TITLE="Бэкап удален"
		RESULT_CODE=0
		printf 'Удалено: %s\n' "$file" >"$RESULT_FILE"
	else
		RESULT_CODE=1
		printf 'Не удалось удалить: %s\n' "$file" >>"$RESULT_FILE"
	fi
}

handle_upload_backup() {
	RESULT_TITLE="Загрузка архива"
	RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"

	if ! command -v owrt-full-backup-upload >/dev/null 2>&1; then
		RESULT_CODE=127
		printf 'Помощник загрузки не установлен: owrt-full-backup-upload\n' >"$RESULT_FILE"
		return
	fi

	owrt-full-backup-upload "$(config_get output_dir /tmp)" >"$RESULT_FILE" 2>&1
	RESULT_CODE="$?"
}

start_backend_job() {
	local title id started log status meta script cmd arg
	title="$1"
	shift

	if [ ! -x "$BACKEND" ]; then
		RESULT_TITLE="$title"
		RESULT_CODE=127
		RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
		printf 'Backend не установлен: %s\n' "$BACKEND" >"$RESULT_FILE"
		return
	fi

	mkdir -p "$JOB_DIR"
	id="$(date +%s)-$$"
	started="$(date +%s)"
	log="$(job_file "$id" log)"
	status="$(job_file "$id" status)"
	meta="$(job_file "$id" meta)"
	script="$(job_file "$id" sh)"

	ACTIVE_JOB="$id"
	printf 'running\n' >"$status"
	{
		printf 'title=%s\n' "$title"
		printf 'started=%s\n' "$started"
	} >"$meta"

	cmd="$(shell_quote "$BACKEND")"
	for arg in "$@"; do
		cmd="$cmd $(shell_quote "$arg")"
	done

	cat >"$script" <<EOF
#!/bin/sh
echo "Начало: \$(date '+%d.%m.%Y %H:%M:%S')"
echo "Создание бэкапа запущено."
$cmd
code="\$?"
echo "\$code" > "$(job_file "$id" code)"
date +%s > "$(job_file "$id" finished)"
if [ "\$code" = "0" ]; then
	echo "Готово."
	echo done > "$status"
else
	echo "Ошибка: код выхода \$code"
	echo failed > "$status"
fi
rm -f "$script"
EOF
	chmod 0700 "$script"
	if command -v start-stop-daemon >/dev/null 2>&1 && start-stop-daemon -S -b -x /bin/sh -- "$script" >"$log" 2>&1; then
		:
	elif command -v setsid >/dev/null 2>&1; then
		setsid sh "$script" >"$log" 2>&1 </dev/null &
	elif command -v nohup >/dev/null 2>&1; then
		nohup sh "$script" >"$log" 2>&1 </dev/null &
	else
		sh "$script" >"$log" 2>&1 </dev/null &
	fi
}

run_backend() {
	RESULT_TITLE="$1"
	shift
	RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
	if [ ! -x "$BACKEND" ]; then
		RESULT_CODE=127
		printf 'Backend не установлен: %s\n' "$BACKEND" >"$RESULT_FILE"
		return
	fi
	"$BACKEND" "$@" >"$RESULT_FILE" 2>&1
	RESULT_CODE="$?"
}

handle_create() {
	local output_dir name firmware
	output_dir="$(param output_dir)"
	name="$(param name)"
	firmware="$(param firmware_image)"
	[ -n "$output_dir" ] || output_dir="$(config_get output_dir /tmp)"
	valid_abs_path "$output_dir" || {
		RESULT_TITLE="Создание бэкапа"
		RESULT_CODE=2
		RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
		printf 'Неверная папка для архива. Используй абсолютный путь, например /mnt/usb.\n' >"$RESULT_FILE"
		return
	}

	set -- create -o "$output_dir"
	[ -n "$name" ] && set -- "$@" -n "$name"
	has_param include_overlay || set -- "$@" --no-overlay
	has_param include_rom && set -- "$@" --include-rom
	has_param include_raw_mtd && set -- "$@" --include-raw-mtd
	[ -n "$firmware" ] && set -- "$@" --firmware-image "$firmware"
	start_backend_job "Создание бэкапа" "$@"
}

handle_inspect() {
	local archive
	archive="$(param archive)"
	valid_abs_path "$archive" || {
		RESULT_TITLE="Просмотр архива"
		RESULT_CODE=2
		RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
		printf 'Неверный путь к архиву.\n' >"$RESULT_FILE"
		return
	}
	run_backend "Просмотр архива" inspect "$archive"
}

handle_restore() {
	local archive confirm
	archive="$(param archive)"
	confirm="$(param confirm)"
	if [ "$confirm" != "RESTORE" ]; then
		RESULT_TITLE="Восстановление"
		RESULT_CODE=2
		RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
		printf 'Для подтверждения введи RESTORE.\n' >"$RESULT_FILE"
		return
	fi
	valid_abs_path "$archive" || {
		RESULT_TITLE="Восстановление"
		RESULT_CODE=2
		RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
		printf 'Неверный путь к архиву.\n' >"$RESULT_FILE"
		return
	}

	set -- restore "$archive" --yes
	has_param restore_configs || set -- "$@" --no-configs
	has_param restore_packages || set -- "$@" --no-packages
	has_param restore_overlay && set -- "$@" --overlay
	has_param flash_firmware && set -- "$@" --flash-firmware
	run_backend "Восстановление" "$@"
}

handle_save_defaults() {
	local output_dir include_overlay include_rom include_raw_mtd keep_days
	RESULT_TITLE="Сохранение настроек"
	RESULT_CODE=0
	RESULT_FILE="${TMPDIR:-/tmp}/owrt-full-backup-result.$$"
	output_dir="$(param default_output_dir)"
	keep_days="$(param keep_days)"
	valid_abs_path "$output_dir" || {
		RESULT_CODE=2
		printf 'Неверная папка для архива.\n' >"$RESULT_FILE"
		return
	}
	case "$keep_days" in ''|*[!0-9]*) keep_days=0 ;; esac
	has_param default_include_overlay && include_overlay=1 || include_overlay=0
	has_param default_include_rom && include_rom=1 || include_rom=0
	has_param default_include_raw_mtd && include_raw_mtd=1 || include_raw_mtd=0

	if command -v uci >/dev/null 2>&1; then
		uci -q batch <<EOF >"$RESULT_FILE" 2>&1
set fullbackup.main=backup
set fullbackup.main.output_dir='$output_dir'
set fullbackup.main.include_overlay='$include_overlay'
set fullbackup.main.include_rom='$include_rom'
set fullbackup.main.include_raw_mtd='$include_raw_mtd'
set fullbackup.main.keep_days='$keep_days'
commit fullbackup
EOF
		RESULT_CODE="$?"
		[ "$RESULT_CODE" = "0" ] && printf 'Настройки сохранены.\n' >>"$RESULT_FILE"
	else
		RESULT_CODE=127
		printf 'Команда uci не найдена.\n' >"$RESULT_FILE"
	fi
}

handle_action() {
	local action
	action="$(param action)"
	case "$action" in
		create) handle_create ;;
		inspect) handle_inspect ;;
		restore) handle_restore ;;
		save_defaults) handle_save_defaults ;;
		delete_backup) handle_delete_backup ;;
		upload_backup) handle_upload_backup ;;
	esac
}

system_value() {
	local value
	case "$1" in
		host)
			if command -v uci >/dev/null 2>&1; then
				value="$(uci -q get system.@system[0].hostname 2>/dev/null || true)"
				[ -n "$value" ] && {
					printf '%s' "$value"
					return
				}
			fi
			hostname 2>/dev/null || printf 'openwrt'
			;;
		release)
			if [ -r /etc/openwrt_release ]; then
				. /etc/openwrt_release 2>/dev/null
				printf '%s %s' "${DISTRIB_ID:-OpenWrt}" "${DISTRIB_RELEASE:-unknown}"
			else
				printf 'OpenWrt unknown'
			fi
			;;
		board)
			if [ -r /tmp/sysinfo/board_name ]; then
				cat /tmp/sysinfo/board_name
			else
				printf 'unknown'
			fi
			;;
	esac
}

storage_widgets() {
	local fs size used avail pct mount usage label
	df -h 2>/dev/null | awk 'NR > 1 { print }' | while read -r fs size used avail pct mount; do
		[ -n "$mount" ] || continue
		usage="${pct%%%}"
		case "$usage" in ''|*[!0-9]*) usage=0 ;; esac
		[ "$usage" -gt 100 ] 2>/dev/null && usage=100
		case "$mount" in
			/) label="Корневой раздел /" ;;
			/rom) label="Раздел прошивки /rom" ;;
			/tmp) label="Временная память /tmp" ;;
			/overlay) label="Изменяемый раздел /overlay" ;;
			/dev) label="Служебный раздел /dev" ;;
			*) label="Раздел $mount" ;;
		esac
		printf '<div class="disk-widget">'
		printf '<div class="disk-top"><div><strong>%s</strong><span>%s</span></div><b>%s</b></div>' "$(h "$label")" "$(h "$fs")" "$(h "$pct")"
		printf '<div class="meter"><span style="width:%s%%"></span></div>' "$usage"
		printf '<div class="disk-meta"><span>Занято: %s</span><span>Свободно: %s</span><span>Всего: %s</span></div>' "$(h "$used")" "$(h "$avail")" "$(h "$size")"
		printf '</div>'
	done
}

temperature_widgets() {
	local path raw whole frac label printed type_path name_path
	printed=0
	for path in /sys/class/thermal/thermal_zone*/temp /sys/class/hwmon/hwmon*/temp*_input; do
		[ -r "$path" ] || continue
		raw="$(cat "$path" 2>/dev/null | tr -dc '0-9')"
		[ -n "$raw" ] || continue
		case "$raw" in *[!0-9]*) continue ;; esac
		if [ "$raw" -ge 1000 ] 2>/dev/null; then
			whole="$((raw / 1000))"
			frac="$(((raw % 1000) / 100))"
		else
			whole="$raw"
			frac=0
		fi
		label="Датчик температуры"
		type_path="${path%/temp}/type"
		name_path="${path%/temp*_input}/name"
		if [ -r "$type_path" ]; then
			label="$(cat "$type_path" 2>/dev/null | sed -n '1p')"
		elif [ -r "$name_path" ]; then
			label="$(cat "$name_path" 2>/dev/null | sed -n '1p')"
		fi
		printed=1
		printf '<div class="temp-widget"><div><strong>%s</strong><span>%s</span></div><b>%s.%s °C</b></div>' "$(h "$label")" "$(h "$path")" "$(h "$whole")" "$(h "$frac")"
	done
	[ "$printed" = "1" ] || printf '<p class="muted">Датчик температуры не найден.</p>'
}

checkbox_attr() {
	[ "$1" = "1" ] && printf ' checked'
}

backup_rows() {
	local dir key file base size mtime
	dir="$(config_get output_dir /tmp)"
	key="$(h "$(param key)")"
	[ -d "$dir" ] || {
		printf '<tr><td colspan="4">Папка для архивов не существует.</td></tr>'
		return
	}
	for file in "$dir"/*-owrt-full-backup.tar.gz; do
		[ -f "$file" ] || continue
		base="$(basename "$file")"
		size="$(ls -lh "$file" 2>/dev/null | awk '{print $5}')"
		mtime="$(ls -l "$file" 2>/dev/null | awk '{print $6" "$7" "$8}')"
		printf '<tr><td><code>%s</code></td><td>%s</td><td>%s</td><td class="actions"><a class="button small" href="%s?key=%s&amp;action=download&amp;file=%s">Скачать</a><form method="post" action="%s" onsubmit="return confirm('"'"'Удалить этот бэкап?'"'"');"><input type="hidden" name="key" value="%s"><input type="hidden" name="action" value="delete_backup"><input type="hidden" name="file" value="%s"><input type="hidden" name="confirm" value="DELETE"><button class="danger small" type="submit">Удалить</button></form></td></tr>' \
			"$(h "$base")" "$(h "$size")" "$(h "$mtime")" "$(self_url)" "$key" "$(h "$file")" "$(self_url)" "$key" "$(h "$file")"
	done
}

render_job_panel() {
	local id status meta log code_file finished_file started finished now elapsed elapsed_text title state_class state_text job_note button_text code estimate_text
	id="$1"
	valid_job_id "$id" || return

	status="$(cat "$(job_file "$id" status)" 2>/dev/null || printf 'missing')"
	meta="$(job_file "$id" meta)"
	log="$(job_file "$id" log)"
	code_file="$(job_file "$id" code)"
	finished_file="$(job_file "$id" finished)"
	started="$(sed -n 's/^started=//p' "$meta" 2>/dev/null | sed -n '1p')"
	title="$(sed -n 's/^title=//p' "$meta" 2>/dev/null | sed -n '1p')"
	code="$(cat "$code_file" 2>/dev/null | sed -n '1p')"
	finished="$(cat "$finished_file" 2>/dev/null | sed -n '1p')"
	[ -n "$title" ] || title="Создание бэкапа"
	case "$started" in ''|*[!0-9]*) started="$(date +%s)" ;; esac
	now="$(date +%s)"
	if [ "$status" != "running" ]; then
		case "$finished" in
			''|*[!0-9]*) ;;
			*) [ "$finished" -ge "$started" ] 2>/dev/null && now="$finished" ;;
		esac
	fi
	elapsed="$((now - started))"
	elapsed_text="$(format_seconds "$elapsed")"
	estimate_text=""

	case "$status" in
		running)
			state_class="running"
			state_text="Выполняется"
			estimate_text="Примерно: 1-3 мин"
			job_note="Страница обновляется каждые 2 секунды. Время примерное: большой overlay, ROM или медленная флешка могут идти дольше."
			button_text="Обновить лог"
			;;
		done)
			state_class="ok"
			state_text="Завершено"
			job_note="Готово. Архив уже появился в списке ниже."
			button_text="Обновить список"
			;;
		failed)
			state_class="error"
			state_text="Ошибка"
			job_note="Создание бэкапа завершилось с ошибкой. Подробности в журнале ниже."
			button_text="Обновить список"
			;;
		*)
			state_class="error"
			state_text="Задача не найдена"
			job_note="Эта задача уже недоступна. Можно обновить страницу и посмотреть список архивов."
			button_text="Обновить список"
			;;
	esac

	printf '<section class="panel span6 job-card %s">' "$state_class"
	printf '<div class="section-head"><div><h2>%s</h2><p>Статус: %s · Время: <span id="job-timer" data-start="%s">%s</span>' "$(h "$title")" "$(h "$state_text")" "$(h "$started")" "$(h "$elapsed_text")"
	if [ -n "$estimate_text" ]; then
		printf ' · <span class="hot-text">%s</span>' "$(h "$estimate_text")"
	fi
	if [ -n "$code" ] && [ "$code" != "0" ]; then
		printf ' · Код ошибки: %s' "$(h "$code")"
	fi
	printf '</p></div><a class="button small" href="%s?key=%s">%s</a></div>' "$(self_url)" "$(h "$(param key)")" "$button_text"
	printf '<p>%s</p><div class="console-title">Журнал выполнения</div>' "$(h "$job_note")"
	printf '<pre class="console">'
	if [ -r "$log" ]; then
		tail -n 120 "$log" | localize_log | html_escape
	else
		printf 'Лог пока пуст. Подожди пару секунд.\n' | html_escape
	fi
	printf '</pre>'
	if [ "$status" = "running" ]; then
		printf '<script>(function(){var el=document.getElementById("job-timer");if(!el)return;var start=parseInt(el.dataset.start,10)||0;function fmt(s){s=Math.max(0,s|0);var m=Math.floor(s/60),r=s%%60;return m>0?m+" мин "+r+" сек":r+" сек";}function tick(){var now=Math.floor(Date.now()/1000);el.textContent=fmt(now-start);}tick();setInterval(tick,1000);}());</script>'
	fi
	printf '</section>'
}

