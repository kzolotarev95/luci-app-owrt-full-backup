h1 { margin: 0; font-size: 22px; }
h2 { margin: 0 0 12px; font-size: 16px; }
p { margin: 6px 0; color: var(--muted); }
.grid { display: grid; gap: 14px; grid-template-columns: repeat(12, 1fr); }
.panel { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 14px; }
.span4 { grid-column: span 4; }
.span6 { grid-column: span 6; }
.span8 { grid-column: span 8; }
.span12 { grid-column: span 12; }
label { display: block; margin: 9px 0 4px; font-weight: 600; }
input[type=text], input[type=number] { width: 100%; border: 1px solid var(--line); border-radius: 6px; background: transparent; color: var(--text); padding: 9px; }
.checks label { font-weight: 500; display: flex; gap: 8px; align-items: center; margin: 8px 0; }
button, .button { display: inline-flex; align-items: center; justify-content: center; min-height: 36px; border: 0; border-radius: 6px; background: var(--accent); color: #fff; padding: 8px 12px; text-decoration: none; font-weight: 700; cursor: pointer; }
.danger { background: var(--bad); }
.muted { color: var(--muted); }
code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
pre { overflow: auto; background: rgba(127,127,127,.12); border-radius: 6px; padding: 10px; }
table { width: 100%; border-collapse: collapse; }
td, th { border-bottom: 1px solid var(--line); padding: 8px 6px; text-align: left; vertical-align: top; }
.status { display: flex; flex-wrap: wrap; gap: 8px; }
.pill { border: 1px solid var(--line); border-radius: 999px; padding: 5px 9px; color: var(--muted); }
@media (max-width: 820px) { .span4, .span6, .span8, .span12 { grid-column: 1 / -1; } main { padding: 12px; } }
</style>
</head>
<body>
<header>
<h1>OpenWrt Full Backup</h1>
<p>Direct web panel, no IPK build required. Keep this URL secret.</p>
</header>
<main>
EOF

	if [ -n "$RESULT_FILE" ]; then
		printf '<section class="panel span12"><h2>%s</h2><p>Exit code: %s</p><pre>' "$(h "$RESULT_TITLE")" "$(h "$RESULT_CODE")"
		html_escape <"$RESULT_FILE"
		printf '</pre></section>'
	fi

	cat <<EOF
<section class="grid">
<div class="panel span4">
<h2>Device</h2>
<div class="status">
<span class="pill">Host: $(h "$(system_value host)")</span>
<span class="pill">Release: $(h "$(system_value release)")</span>
<span class="pill">Board: $(h "$(system_value board)")</span>
</div>
<pre>$(df -h 2>/dev/null | html_escape)</pre>
</div>

<form class="panel span8" method="post" action="$(self_url)">
<h2>Create backup</h2>
<input type="hidden" name="key" value="$key">
<input type="hidden" name="action" value="create">
<label>Output directory</label>
<input type="text" name="output_dir" value="$(h "$output_dir")">
<label>Archive name</label>
<input type="text" name="name" placeholder="auto name">
<label>Firmware image path</label>
<input type="text" name="firmware_image" placeholder="/tmp/openwrt-sysupgrade.bin">
<div class="checks">
<label><input type="checkbox" name="include_overlay" value="1"$(checkbox_attr "$include_overlay")> include /overlay/upper</label>
<label><input type="checkbox" name="include_rom" value="1"$(checkbox_attr "$include_rom")> include /rom rootfs snapshot</label>
<label><input type="checkbox" name="include_raw_mtd" value="1"$(checkbox_attr "$include_raw_mtd")> include raw MTD dumps</label>
</div>
<button type="submit">Create backup</button>
</form>

<div class="panel span12">
<h2>Backups in $(h "$output_dir")</h2>
<table><thead><tr><th>File</th><th>Size</th><th>Date</th><th>Action</th></tr></thead><tbody>
$(backup_rows)
</tbody></table>
</div>

<form class="panel span6" method="post" action="$(self_url)">
<h2>Inspect archive</h2>
<input type="hidden" name="key" value="$key">
<input type="hidden" name="action" value="inspect">
<label>Archive path</label>
<input type="text" name="archive" placeholder="/mnt/usb/router-owrt-full-backup.tar.gz">
<button type="submit">Inspect</button>
</form>

<form class="panel span6" method="post" action="$(self_url)">
<h2>Restore archive</h2>
<input type="hidden" name="key" value="$key">
<input type="hidden" name="action" value="restore">
<label>Archive path</label>
<input type="text" name="archive" placeholder="/mnt/usb/router-owrt-full-backup.tar.gz">
<div class="checks">
<label><input type="checkbox" name="restore_configs" value="1" checked> restore configs</label>
<label><input type="checkbox" name="restore_packages" value="1"> reinstall package list</label>
<label><input type="checkbox" name="restore_overlay" value="1"> restore overlay snapshot</label>
<label><input type="checkbox" name="flash_firmware" value="1"> flash firmware image and reboot</label>
</div>
<label>Type RESTORE</label>
<input type="text" name="confirm" autocomplete="off">
<button class="danger" type="submit">Run restore</button>
</form>

<form class="panel span6" method="post" action="$(self_url)">
<h2>Defaults</h2>
<input type="hidden" name="key" value="$key">
<input type="hidden" name="action" value="save_defaults">
<label>Default output directory</label>
<input type="text" name="default_output_dir" value="$(h "$output_dir")">
<label>Keep days, 0 disables cleanup</label>
<input type="number" min="0" name="keep_days" value="$(h "$keep_days")">
<div class="checks">
<label><input type="checkbox" name="default_include_overlay" value="1"$(checkbox_attr "$include_overlay")> include overlay by default</label>
<label><input type="checkbox" name="default_include_rom" value="1"$(checkbox_attr "$include_rom")> include ROM by default</label>
<label><input type="checkbox" name="default_include_raw_mtd" value="1"$(checkbox_attr "$include_raw_mtd")> include raw MTD by default</label>
</div>
<button type="submit">Save defaults</button>
</form>

<div class="panel span6">
<h2>Git install / remove</h2>
<p>Clone install:</p>
<pre>git clone $(h "$PROJECT_URL").git
cd openwrt-full-backup
sh install.sh</pre>
<p>One-line install:</p>
<pre>wget -O - $(h "$RAW_URL")/install.sh | sh</pre>
<p>Remove:</p>
<pre>wget -O - $(h "$RAW_URL")/uninstall.sh | sh</pre>
</div>
</section>
</main>
</body>
</html>
EOF
}

read_request
if ! authorized; then
	http_unauthorized
	exit 0
fi

if [ "$(param action)" = "download" ]; then
	download_file
fi

if [ "${REQUEST_METHOD:-GET}" = "POST" ]; then
	handle_action
fi

page
